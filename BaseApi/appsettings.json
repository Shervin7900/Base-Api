{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Sentry": {
    "Dsn": "",
    "MaxBreadcrumbs": 50,
    "SendDefaultPii": false,
    "MinimumBreadcrumbLevel": "Debug",
    "MinimumEventLevel": "Warning",
    "AttachStacktrace": true,
    "TracesSampleRate": 0.1
  },
  "Observability": {
    "GrafanaUrl": "http://localhost:3000",
    "SentryUrl": "",
    "LokiUrl": "http://localhost:3100"
  }
}
